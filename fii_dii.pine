//@version=5
indicator("FII & DII Flow", overlay=false, max_bars_back=500)

// Real NSE cash market data only
// Pre Jun-2026: no verified data — add historical if needed
// Auto-updated daily by GitHub Actions after this base is committed

d = str.format("{0,date,yyyy-MM-dd}", time)

fii_val = switch d
    "2026-06-01" => -3911.68
    "2026-06-02" => -8362.92
    "2026-06-03" => -5616.56
    "2026-06-04" => -4447.06
    "2026-06-05" => -8776.25
    "2026-06-08" => -5555.67
    "2026-06-09" => -4566.03
    "2026-06-10" => -2124.98
    "2026-06-11" => -1987.09
    "2026-06-12" => -1082.18
    "2026-06-15" =>   200.05
    "2026-06-16" =>  -749.18
    "2026-06-17" =>   101.59
    "2026-06-18" => -1025.20
    "2026-06-19" =>  4859.07
    "2026-06-22" =>  -635.91
    "2026-06-23" =>    17.86
    => float(na)

dii_val = switch d
    "2026-06-01" =>  5109.13
    "2026-06-02" =>  9589.32
    "2026-06-03" =>  5740.89
    "2026-06-04" =>  4360.14
    "2026-06-05" =>  9133.57
    "2026-06-08" =>  5165.24
    "2026-06-09" =>  6159.48
    "2026-06-10" =>  3123.95
    "2026-06-11" =>  4224.51
    "2026-06-12" =>  5341.29
    "2026-06-15" =>  3189.26
    "2026-06-16" =>     0.06
    "2026-06-17" =>  1561.40
    "2026-06-18" =>  3516.81
    "2026-06-19" => -1159.64
    "2026-06-22" =>  1035.72
    "2026-06-23" =>   680.21
    => float(na)

fii_col = not na(fii_val) and fii_val >= 0 ? color.new(color.green, 15) : color.new(color.red, 15)
dii_col = not na(dii_val) and dii_val >= 0 ? color.new(color.teal, 15)  : color.new(color.orange, 15)

plot(fii_val, style=plot.style_columns, color=fii_col, title="FII Net ₹Cr")
plot(dii_val, style=plot.style_columns, color=dii_col, title="DII Net ₹Cr")
hline(0, "Zero", color=color.gray, linewidth=1)

var table t = table.new(position.top_right, 2, 3, border_width=1)
if barstate.islast and not na(fii_val)
    table.cell(t, 0, 0, "Entity",  bgcolor=color.gray, text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Net ₹Cr", bgcolor=color.gray, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "FII CM",  bgcolor=fii_col,    text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(fii_val, "#,###.##"), bgcolor=fii_col, text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "DII CM",  bgcolor=dii_col,    text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(dii_val, "#,###.##"), bgcolor=dii_col, text_color=color.white, text_size=size.small)
